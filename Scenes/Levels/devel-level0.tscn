[node name="PlayerHealthHint" type="Label" parent="Control/ColorRect" unique_id=996247786]
layout_mode = 0
offset_left = 61.0
offset_top = 158.0
offset_right = 754.0
offset_bottom = 311.0
text = "When the player reaches low health your heartbeat will change
depending on if the setting is enable, but it's buggy. Also the proximity of the monster will
change the heartbeat, but it won't change if you have a debuff from low health.

If the player reaches 0 health, the player will die and this will require a reload until
a system is worked out for respawning."
horizontal_alignment = 1
vertical_alignment = 1

[node name="PlayerStaminaHint" type="Label" parent="Control/ColorRect" unique_id=721750976]
layout_mode = 0
offset_left = 107.0
offset_top = 308.0
offset_right = 587.0
offset_bottom = 356.0
text = "When the player is running using the 'Shift' key it will drain stamina rapidly.
To regain stamina rapidly you must stop moving entirely or hide.
You still regain stamina while moving but it's slower."
horizontal_alignment = 1
vertical_alignment = 1

[node name="PlayerAmmoHint" type="Label" parent="Control/ColorRect" unique_id=464385355]
layout_mode = 0
offset_left = 125.0
offset_top = 382.0
offset_right = 572.0
offset_bottom = 447.0
text = "In this game ammo will be crucial for stunning the monster
if you have 0 ammo you no longer can shoot to stun the monster, this
can be considered a really bad situation. This is still WIP.
In the future, there will be pickups for health and ammo."
horizontal_alignment = 1
vertical_alignment = 1
